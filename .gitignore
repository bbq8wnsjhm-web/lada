# Ignore everything by default
*

# Keep git metadata files
!.gitignore
!README.md
!index.html
!styles.css
!script.js
!products.js

# Keep project context docs
!docs/
docs/*
!docs/PROJECT_CONTEXT.md
!docs/WORKSPACE_MAP.md
!docs/README.md
!docs/.gitkeep

# Keep code
!scripts/
scripts/*
!scripts/*.py
!scripts/README.md
!scripts/.gitkeep

# Keep lightweight prototype code
!prototype/
prototype/*
!prototype/kinetic-type/
prototype/kinetic-type/*
!prototype/kinetic-type/index.html
!prototype/kinetic-type/styles.css
!prototype/kinetic-type/script.js
!prototype/.gitkeep
!prototype/kinetic-type/.gitkeep

# Keep skeleton folders only
!assets/
assets/*
!assets/.gitkeep
!assets/media/
assets/media/*
!assets/media/.gitkeep
!assets/media/site-background.png
!assets/media/site-logo.png
!assets/catalog/
assets/catalog/*
!assets/catalog/earrings/
assets/catalog/earrings/*
!assets/catalog/earrings/*.png
!assets/catalog/ginger/
assets/catalog/ginger/*
!assets/catalog/ginger/*.png
!assets/catalog/nurofen/
assets/catalog/nurofen/*
!assets/catalog/nurofen/*.png
!assets/catalog/pilim/
assets/catalog/pilim/*
!assets/catalog/pilim/*.png
!assets/catalog/rings/
assets/catalog/rings/*
!assets/catalog/rings/*.png
!assets/working/
assets/working/*
!assets/working/.gitkeep

!archive/
archive/*
!archive/.gitkeep
!assets/catalog/new/
assets/catalog/new/*
!assets/catalog/new/*.png
!assets/catalog/new/*.jpg
!assets/catalog/new/*.JPG
